# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real credentials.
#
# Used by scripts/tools/infinite_campus/infinitecampus.py

# Optional path to an external secrets file
SECRETS_FILE=

# Microsoft SSO login used to authenticate to Infinite Campus
INFINITE_CAMPUS_MS_SSO_LOGIN=
INFINITE_CAMPUS_MS_SSO_PASSWORD=

# Email account the report is sent FROM (app password recommended)
INFINITE_CAMPUS_FROM_EMAIL=
INFINITE_CAMPUS_FROM_PASSWORD=

# Comma-separated list of recipients
INFINITE_CAMPUS_EMAIL_RECIPIENTS=

# Infinite Campus endpoints
INFINITE_CAMPUS_LOGIN_URL=
INFINITE_CAMPUS_GRADES_API=
INFINITE_CAMPUS_ASSIGN_API=
